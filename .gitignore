# Python cache and bytecode
__pycache__/
*.py[cod]
*$py.class

# Test and tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments and dependency caches
.venv/
venv/
env/
ENV/
.pydeps/

# Temporary files
.tmp/
tmp/
temp/
*.tmp
*.log

# Generated datasets and numeric artifacts
data/
*.npz
*.npy
*.mph

# Model checkpoints and training outputs
checkpoints/
runs/
*.pt
*.pth
*.ckpt

# Generated result artifacts
# Large or frequently regenerated outputs stay ignored. Use `git add -f` only
# when a task explicitly allows a specific metrics/summary record.
results/*
!results/manifests/
!results/manifests/*.json
!results/templates/
!results/templates/*.json
!results/templates/*.csv
results/metrics/
results/summaries/
results/previews/
results/loss_curves/
results/archive/
results/sweeps/
*.png
*.jpg
*.jpeg

# Local editor and OS metadata
.vscode/
.idea/
.claude/
.claudian/
.obsidian/
notes/
.DS_Store
Thumbs.db

# Local environment files
.env
.env.*
!.env.example
